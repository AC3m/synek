{
  "name": "synek",
  "version": "0.10.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "prepare": "husky",
    "typecheck": "react-router typegen && tsc",
    "verify:app": "pnpm format && pnpm typecheck && pnpm test:run",
    "verify": "pnpm verify:app && pnpm supabase:functions:check",
    "supabase:functions:check": "bash scripts/check-supabase-functions.sh",
    "seed": "tsx supabase/seed.ts",
    "format": "prettier --write \"app/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "supabase:install": "bash scripts/install-supabase-cli.sh",
    "supabase:deploy:strava": "bash scripts/supabase-deploy-strava.sh",
    "release": "release-it"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@tryvital/vital-link": "^0.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.13",
    "isbot": "^5.1.31",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router": "7.12.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@release-it/conventional-changelog": "^10.0.5",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "release-it": "^19.2.4",
    "shadcn": "^3.8.5",
    "supabase": "^2.89.1",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide",
      "supabase"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,css,json,md,yml,yaml,html}": "prettier --write"
  }
}
